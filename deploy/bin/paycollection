#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="${PAYCOLLECTION_HOME:-/opt/paycollection}"
SCRIPTS_DIR="${INSTALL_DIR}/deploy/scripts"
COMMON_SH="${SCRIPTS_DIR}/common.sh"

if [[ -f "${COMMON_SH}" ]]; then
  # shellcheck source=/dev/null
  source "${COMMON_SH}"
else
  SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts" && pwd)"
  INSTALL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
  COMMON_SH="${SCRIPTS_DIR}/common.sh"
  if [[ -f "${COMMON_SH}" ]]; then
    # shellcheck source=/dev/null
    source "${COMMON_SH}"
  fi
fi

run_script() {
  local script="$1"
  shift || true
  local path="${SCRIPTS_DIR}/${script}"
  if [[ ! -f "${path}" ]]; then
    echo "Script not found: ${path}" >&2
    return 1
  fi
  bash "${path}" "$@"
}

print_banner() {
  local version panel_status bot_status db_status ssl_status
  version="$(panel_version 2>/dev/null || echo 'v1.0.0')"
  panel_status="$(service_state frontend 2>/dev/null || echo 'Unknown')"
  bot_status="$(service_state bot 2>/dev/null || echo 'Unknown')"
  db_status="$(service_state postgres 2>/dev/null || echo 'Unknown')"
  ssl_status="$(ssl_state 2>/dev/null || echo 'Unknown')"

  cat <<EOF
╔══════════════════════════════════════════════════════╗
║            PayCollection Management                  ║
║                Version ${version}                    ║
╠══════════════════════════════════════════════════════╣
║ 0. Exit                                              ║
╠══════════════════════════════════════════════════════╣
║ 1. Install                                           ║
║ 2. Update                                            ║
║ 3. Backup                                            ║
║ 4. Restore Backup                                    ║
║ 5. Uninstall                                         ║
╠══════════════════════════════════════════════════════╣
║ 6. Start Services                                    ║
║ 7. Stop Services                                     ║
║ 8. Restart Services                                  ║
║ 9. View Status                                       ║
║ 10. View Logs                                        ║
╠══════════════════════════════════════════════════════╣
║ 11. Health Check                                     ║
║ 12. SSL Status                                       ║
║ 13. Renew SSL                                        ║
╠══════════════════════════════════════════════════════╣
║ 14. Database Backup                                  ║
║ 15. Database Restore                                 ║
║ 16. Database Console                                 ║
╠══════════════════════════════════════════════════════╣
║ 17. Change Domain                                    ║
║ 18. Change Bot Token                                 ║
║ 19. Regenerate Secrets                               ║
║ 20. View Current Configuration                       ║
╠══════════════════════════════════════════════════════╣
║ 21. Enable Telegram Proxy                            ║
║ 22. Disable Telegram Proxy                           ║
║ 23. Configure Telegram Proxy                         ║
╠══════════════════════════════════════════════════════╣
║ 24. Docker Status                                    ║
║ 25. Update Docker Images                             ║
║ 26. System Information                               ║
╚══════════════════════════════════════════════════════╝

Panel Status : ${panel_status}
Bot Status   : ${bot_status}
Database     : ${db_status}
SSL          : ${ssl_status}
Version      : ${version}
EOF
}

interactive_menu() {
  while true; do
    echo
    print_banner
    echo
    read -r -p "Please enter your selection [0-26]: " choice
    case "${choice}" in
      0) exit 0 ;;
      1) run_script install.sh ;;
      2) run_script update.sh ;;
      3) run_script backup.sh ;;
      4)
        read -r -p "Backup archive path: " archive
        run_script restore.sh "${archive}"
        ;;
      5) run_script uninstall.sh ;;
      6) run_script start.sh ;;
      7) run_script stop.sh ;;
      8) run_script restart.sh ;;
      9) run_script status.sh ;;
      10)
        read -r -p "Service name (optional): " svc
        run_script logs.sh "${svc}"
        ;;
      11) run_script health.sh ;;
      12) run_script ssl-status.sh ;;
      13) run_script ssl-renew.sh ;;
      14) run_script db-backup.sh ;;
      15)
        read -r -p "Database dump path: " dump
        run_script db-restore.sh "${dump}"
        ;;
      16) run_script db-console.sh ;;
      17) run_script change-domain.sh ;;
      18) run_script change-bot-token.sh ;;
      19) run_script regenerate-secrets.sh ;;
      20) run_script view-config.sh ;;
      21) run_script enable-telegram-proxy.sh ;;
      22) run_script disable-telegram-proxy.sh ;;
      23) run_script configure-telegram-proxy.sh ;;
      24) run_script docker-status.sh ;;
      25) run_script update-docker-images.sh ;;
      26) run_script system-info.sh ;;
      *) echo "Invalid selection." ;;
    esac
    echo
    read -r -p "Press Enter to continue..."
  done
}

usage() {
  cat <<EOF
PayCollectionBOT deployment CLI

Usage:
  paycollection                   Interactive management menu
  paycollection install           Run production installer
  paycollection update            Pull latest code, backup, rebuild, migrate, health-check
  paycollection backup            Backup database and uploads
  paycollection restore <file>    Restore from backup archive
  paycollection start             Start all services
  paycollection stop              Stop all services
  paycollection restart           Restart all services
  paycollection status            Show container status
  paycollection logs [service]    Tail service logs
  paycollection health            Run health check

Environment:
  PAYCOLLECTION_HOME  Installation directory (default: /opt/paycollection)
EOF
}

cmd="${1:-}"
shift || true

case "${cmd}" in
  install)
    run_script install.sh "$@"
    ;;
  update)
    run_script update.sh "$@"
    ;;
  backup)
    run_script backup.sh "$@"
    ;;
  restore)
    run_script restore.sh "$@"
    ;;
  start)
    run_script start.sh "$@"
    ;;
  stop)
    run_script stop.sh "$@"
    ;;
  restart)
    run_script restart.sh "$@"
    ;;
  status)
    run_script status.sh "$@"
    ;;
  logs)
    run_script logs.sh "$@"
    ;;
  health)
    run_script health.sh "$@"
    ;;
  ""|-m|--menu)
    interactive_menu
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: ${cmd}" >&2
    usage
    exit 1
    ;;
esac
