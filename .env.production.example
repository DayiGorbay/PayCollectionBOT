# PayCollectionBOT — Production Environment
# Copy to /opt/paycollection/.env (install.sh generates this automatically)

ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1

# Generated by install.sh
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://paycollection:CHANGE_ME@postgres:5432/paycollection

JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

DOMAIN=panel.example.com
CORS_ORIGINS=https://panel.example.com
TRUSTED_HOSTS=panel.example.com,localhost,127.0.0.1,backend

INTERNAL_API_KEY=
BOT_TOKEN=
BOT_HEALTH_URL=http://bot:8090/health

# Optional Telegram proxy for Bot API (requires aiohttp-socks for socks5)
BOT_PROXY_ENABLED=false
BOT_PROXY_URL=

BACKEND_API_URL=http://backend:8000/api/v1
UPLOADS_DIR=/app/data/uploads/receipts

# Bot settings (prompted during install.sh)
PAYMENT_CARD_NUMBER=
CHANNEL_ID=
CHANNEL_LINK=
CHANNEL_USERNAME=
ADMIN_TELEGRAM_ID=
REQUIRE_CHANNEL_JOIN=true
MIN_TOPUP_RIAL=10000
LOG_LEVEL=INFO
REFERRAL_DAILY_CAP=50
